# Absolute path to the local SQLite DB. MUST be absolute (file:/abs/.../prisma/dev.db)
# so the Prisma CLI and the generated client resolve to the same file. A relative
# `file:./dev.db` splits into prisma/dev.db (CLI) vs node_modules/.prisma/client/dev.db (runtime).
DATABASE_URL=file:/absolute/path/to/qlerify-live/prisma/dev.db

# Anthropic Claude API key — the PLATFORM DEFAULT account used by every org that
# has not configured its own key in Organisation admin.
# Get one at https://console.anthropic.com — workspace member or owner role required.
# Copy this file to .env (gitignored) and fill in the value.
ANTHROPIC_API_KEY=sk-ant-...

# Master key for encrypting per-organization secrets at rest (e.g. an org's own
# Anthropic or Qlerify key set in Organisation admin). 32 bytes, hex. Generate with:
#   openssl rand -hex 32
# Required only to set/read per-org keys; without it orgs fall back to the
# platform default keys. Rotating it invalidates stored per-org keys.
PLATFORM_ENCRYPTION_KEY=

# Qlerify MCP endpoint + API key — the PLATFORM DEFAULT Qlerify account used to
# fetch a model behind the Model page's "⤓ Reload from link" for every org that
# has not configured its own key in Organisation admin. Each org can override both
# with its own (encrypted) key there. In local dev these may be omitted and the
# creds fall back to ~/.claude.json (mcpServers.qlerify) instead.
QLERIFY_MCP_URL=
QLERIFY_MCP_API_KEY=

# Optional: override the model and effort.
# CHAT_MODEL=claude-sonnet-4-6
# CHAT_EFFORT=medium
