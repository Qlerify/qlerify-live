# You normally do NOT edit this file by hand. `npm run dev` (or `npm run setup`)
# fills in everything below automatically. The only value you might add is a
# platform-default ANTHROPIC_API_KEY — and even that is optional: each org pastes
# its own key in Organisation admin.

# Local SQLite DB path. Leave BLANK — setup fills it with an absolute path, and
# the runtime self-heals a blank/relative value to <repo>/prisma/dev.db. (Only the
# Prisma CLI needs the absolute value in this file; the runtime computes its own.)
DATABASE_URL=

# Anthropic Claude API key — optional PLATFORM DEFAULT used by orgs that have not
# set their own key in Organisation admin. Leave blank for a client install: each
# org adds its own key in the UI. Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Master key for encrypting per-organization secrets at rest (an org's own
# Anthropic or Qlerify key set in Organisation admin). 32 bytes, hex.
# AUTO-GENERATED by setup — leave blank. Do NOT change it once set: rotating it
# invalidates every org's stored per-org keys.
PLATFORM_ENCRYPTION_KEY=

# Qlerify MCP endpoint + API key — the PLATFORM DEFAULT Qlerify account used to
# fetch a model behind the Model page's "⤓ Reload from link" for every org that
# has not configured its own key in Organisation admin. Each org can override both
# with its own (encrypted) key there. In local dev these may be omitted and the
# creds fall back to ~/.claude.json (mcpServers.qlerify) instead.
QLERIFY_MCP_URL=
QLERIFY_MCP_API_KEY=

# Optional: override the model and effort.
# CHAT_MODEL=claude-sonnet-4-6
# CHAT_EFFORT=medium
