{
  "name": "ericsson-hw-flow-sim",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "End-to-end demo simulator for the Ericsson HW Flow event storming workflow",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "tsx src/kernel/codegen/generate.ts",
    "codegen:ai": "tsx src/kernel/codegen/ai.ts",
    "sim": "tsx src/simulator/runner.ts",
    "sim:disruptions": "tsx src/simulator/runner.ts --with-disruptions",
    "db:push": "prisma db push",
    "db:reset": "rm -f prisma/dev.db prisma/dev.db-journal && prisma db push --skip-generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
