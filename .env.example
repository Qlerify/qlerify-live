# You normally do NOT edit this file by hand. `npm run dev` (or `npm run setup`)
# fills in everything below automatically. The only value you might add is a
# platform-default ANTHROPIC_API_KEY — and even that is optional: each org pastes
# its own key in Organisation admin.

# Local SQLite DB path. Leave BLANK — setup fills it with an absolute path, and
# the runtime self-heals a blank/relative value to <repo>/prisma/dev.db. (Only the
# Prisma CLI needs the absolute value in this file; the runtime computes its own.)
DATABASE_URL=

# Anthropic Claude API key — optional PLATFORM DEFAULT used by orgs that have not
# set their own key in Organisation admin. Leave blank for a client install: each
# org adds its own key in the UI. Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# --- AI/LLM provider (three deployment states) -------------------------------
# 1. LOCKED:   LLM_SETTINGS_LOCKED=true + a provider below. The per-org UI is
#              read-only (it explains what's pinned, never any secrets) and
#              per-org writes are rejected server-side. The server refuses to
#              boot if locked without a working provider.
# 2. OPEN with fallback: lock unset/false, provider below set. Orgs may pick
#              their own provider in Org Admin (Anthropic key, or AWS Bedrock
#              with their own AWS credentials); unconfigured orgs use this default.
# 3. OPEN without fallback: lock unset/false, nothing below. Every org must
#              configure its own provider before AI features work.
LLM_SETTINGS_LOCKED=

# Platform-default provider: blank/anything = first-party Anthropic API (uses
# ANTHROPIC_API_KEY above); "bedrock" = Claude through this deployment's own AWS
# account (the dedicated-install case).
LLM_PROVIDER=
# Region where Claude is enabled in the AWS account (falls back to AWS_REGION).
BEDROCK_REGION=
# Bedrock MODEL or inference-profile id — NOT a bare alias. Account/region-specific,
# so there is no default. Examples:
#   anthropic.claude-sonnet-4-5-20250929-v1:0
#   us.anthropic.claude-sonnet-4-5-20250929-v1:0   (cross-region inference profile)
BEDROCK_MODEL=
# Platform Bedrock credentials resolve via the standard AWS chain — prefer an IAM
# role on the host/pod (nothing to set here). To use static keys instead, set the
# usual AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY; the SDK reads them. (Per-org
# Bedrock configured in the UI always uses the org's own explicit credentials,
# stored encrypted.)
# Model note: the chat agent sends adaptive thinking + effort, which need a
# recent Claude (Sonnet 4.x / Opus 4.x / Sonnet 5) — pick a Bedrock model that
# supports them.

# Master key for encrypting per-organization secrets at rest (an org's own
# Anthropic or Qlerify key set in Organisation admin). 32 bytes, hex.
# AUTO-GENERATED by setup — leave blank. Do NOT change it once set: rotating it
# invalidates every org's stored per-org keys.
PLATFORM_ENCRYPTION_KEY=

# Qlerify Modeller access for the Model page's "⤓ Reload from link".
#   QLERIFY_MCP_API_KEY — optional PLATFORM-DEFAULT key, used by any org that has
#     not set its own key in Organisation admin. Leave blank for a client install:
#     each org pastes its own (encrypted) key in the UI. In local dev the key can
#     also come from ~/.claude.json (mcpServers.qlerify).
#   QLERIFY_MCP_URL — almost never needed. The endpoint defaults to
#     https://mcp.qlerify.com; only set this to point at a white-labelled Modeller.
QLERIFY_MCP_URL=
QLERIFY_MCP_API_KEY=

# Optional: override the model and effort.
# CHAT_MODEL=claude-sonnet-4-6
# CHAT_EFFORT=medium
