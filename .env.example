# Absolute path to the local SQLite DB. MUST be absolute (file:/abs/.../prisma/dev.db)
# so the Prisma CLI and the generated client resolve to the same file. A relative
# `file:./dev.db` splits into prisma/dev.db (CLI) vs node_modules/.prisma/client/dev.db (runtime).
DATABASE_URL=file:/absolute/path/to/qlerify-live/prisma/dev.db

# Anthropic Claude API key for the chat assistant.
# Get one at https://console.anthropic.com — workspace member or owner role required.
# Copy this file to .env (gitignored) and fill in the value.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model and effort.
# CHAT_MODEL=claude-sonnet-4-6
# CHAT_EFFORT=medium
