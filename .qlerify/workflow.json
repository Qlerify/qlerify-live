{
  "$schema": "https://app.qlerify.com/schemas/domain-model/v1.json",
  "version": 1,
  "boundedContext": "Identity & Access",
  "roles": [
    "User",
    "Automation"
  ],
  "domainEvents": {
    "AccountRegistered": {
      "event": "Account Registered",
      "role": "User",
      "follows": [
        "start"
      ],
      "command": {
        "$ref": "#/schemas/commands/RegisterAccount"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Account"
      },
      "acceptanceCriteria": [
        "Given a visitor provides a valid email, password and required profile fields and agrees to the terms, When they submit sign-up, Then a Cognito account is created in UNCONFIRMED state and a confirmation-code email is sent.",
        "Given an email that is already registered, When the visitor submits sign-up, Then sign-up is rejected with an 'email already taken' message directing them to log in or reset password.",
        "Given a password that violates the password policy, When the visitor submits sign-up, Then sign-up is rejected with an invalid-password message."
      ]
    },
    "AccountConfirmed": {
      "event": "Account Confirmed",
      "role": "User",
      "follows": [
        {
          "$ref": "#/domainEvents/AccountRegistered"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/ConfirmAccount"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Account"
      },
      "acceptanceCriteria": [
        "Given an unconfirmed account and a valid registration code, When the user submits the code, Then the account becomes CONFIRMED and the user is directed to log in.",
        "Given an already-confirmed account, When the user submits a code, Then they are told it is already verified and redirected to login.",
        "Given an expired registration code, When the user submits it, Then they are told the code expired and resend is unlocked."
      ]
    },
    "AccountLoggedIn": {
      "event": "Account Logged In",
      "role": "User",
      "follows": [
        {
          "$ref": "#/domainEvents/AccountConfirmed"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/LogIn"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Account"
      },
      "acceptanceCriteria": [
        "Given a confirmed account with correct credentials and no MFA, When the user logs in, Then tokens are issued, a session is established, and they land on the dashboard.",
        "Given correct credentials and MFA enabled, When the user logs in, Then an MFA (SOFTWARE_TOKEN_MFA) challenge is returned and a valid 6-digit TOTP code completes login.",
        "Given an unconfirmed account, When the user attempts to log in, Then they are redirected to confirmation with an auto-resent code.",
        "Given incorrect credentials, When the user logs in, Then login fails with 'Incorrect email or password.'"
      ]
    }
  },
  "schemas": {
    "commands": {
      "RegisterAccount": {
        "required": [
          "email",
          "password",
          "firstname",
          "lastname",
          "company"
        ],
        "fields": [
          {
            "name": "email",
            "hideInForm": false
          },
          {
            "name": "password",
            "hideInForm": false
          },
          {
            "name": "firstname",
            "hideInForm": false
          },
          {
            "name": "lastname",
            "hideInForm": false
          },
          {
            "name": "company",
            "hideInForm": false
          },
          {
            "name": "phoneNumber",
            "hideInForm": false
          },
          {
            "name": "referralSource",
            "hideInForm": false
          },
          {
            "name": "usageIntent",
            "hideInForm": false
          }
        ]
      },
      "ConfirmAccount": {
        "required": [
          "email",
          "confirmationCode"
        ],
        "fields": [
          {
            "name": "email",
            "hideInForm": false
          },
          {
            "name": "confirmationCode",
            "hideInForm": false
          }
        ]
      },
      "LogIn": {
        "required": [
          "email",
          "password"
        ],
        "fields": [
          {
            "name": "email",
            "hideInForm": false
          },
          {
            "name": "password",
            "hideInForm": false
          }
        ]
      }
    },
    "entities": {
      "Account": {
        "description": "Authentication identity managed by AWS Cognito; the credential and verification record behind a person's login.",
        "required": [
          "id",
          "email",
          "status",
          "firstname",
          "lastname"
        ],
        "fields": [
          {
            "name": "id",
            "description": "Cognito subject/username identifying the account",
            "exampleData": [
              "a1b2c3d4-1111-2222-3333-444455556666",
              "f0e9d8c7-aaaa-bbbb-cccc-ddddeeeeffff",
              "12345678-90ab-cdef-1234-567890abcdef"
            ],
            "dataType": "string"
          },
          {
            "name": "email",
            "description": "Login email; the Cognito username, unique across accounts",
            "exampleData": [
              "ada@example.com",
              "grace@company.org",
              "linus@mail.net"
            ],
            "dataType": "string"
          },
          {
            "name": "status",
            "description": "Cognito confirmation status",
            "exampleData": [
              "UNCONFIRMED",
              "CONFIRMED",
              "CONFIRMED"
            ],
            "dataType": "string"
          },
          {
            "name": "firstname",
            "description": "Given name (Cognito given_name)",
            "exampleData": [
              "Ada",
              "Grace",
              "Linus"
            ],
            "dataType": "string"
          },
          {
            "name": "lastname",
            "description": "Family name (Cognito family_name)",
            "exampleData": [
              "Lovelace",
              "Hopper",
              "Torvalds"
            ],
            "dataType": "string"
          },
          {
            "name": "phoneNumber",
            "description": "Phone number in E.164 format (Cognito phone_number)",
            "exampleData": [
              "+14155550100",
              "+442071234567",
              "+46812345678"
            ],
            "dataType": "string"
          },
          {
            "name": "company",
            "description": "Organisation name supplied at sign-up (Cognito custom:organisation)",
            "exampleData": [
              "Acme Inc",
              "Globex",
              "Initech"
            ],
            "dataType": "string"
          },
          {
            "name": "referralSource",
            "description": "How the user heard about Qlerify (Cognito custom:referral_source)",
            "exampleData": [
              "Google search",
              "A colleague",
              "Conference talk"
            ],
            "dataType": "string"
          },
          {
            "name": "usageIntent",
            "description": "How the user intends to use Qlerify (Cognito custom:usage_intent)",
            "exampleData": [
              "Model our order process",
              "Document microservices",
              "Teach DDD"
            ],
            "dataType": "string"
          },
          {
            "name": "mfaEnabled",
            "description": "Whether software-token (TOTP) MFA is enabled",
            "exampleData": [
              "false",
              "true",
              "false"
            ],
            "dataType": "boolean"
          }
        ]
      }
    }
  },
  "externalBoundedContexts": {
    "QlerifyPlatform": {
      "domainEvents": {
        "UserRegistered": {
          "event": "User Registered",
          "role": "Automation",
          "follows": [
            {
              "$ref": "#/domainEvents/AccountLoggedIn"
            }
          ],
          "command": {
            "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/commands/CreateUser"
          },
          "aggregateRoot": {
            "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/User"
          },
          "readModels": [
            {
              "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/queries/GetCurrentUser",
              "description": "Get Current User"
            }
          ],
          "acceptanceCriteria": [
            "Given a confirmed user logging in for the first time with no Qlerify profile, When the session initializes, Then a Qlerify user profile is created in DynamoDB from the Cognito attributes.",
            "Given a returning user with an existing profile, When they log in, Then the profile is updated and the login counter is incremented and no new profile is created."
          ]
        },
        "OrganisationCreated": {
          "event": "Organisation Created",
          "role": "Automation",
          "follows": [
            {
              "$ref": "#/externalBoundedContexts/QlerifyPlatform/domainEvents/UserRegistered"
            }
          ],
          "command": {
            "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/commands/CreateOrganisation"
          },
          "aggregateRoot": {
            "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/Organisation"
          },
          "acceptanceCriteria": [
            "Given a first-time user whose sign-up included a company name, When their profile is created, Then an organisation with that name is created and owned by the user.",
            "Given a first-time user with no company name, When they reach the dashboard, Then they are prompted to create their first organisation manually."
          ]
        },
        "ProjectCreated": {
          "event": "Project Created",
          "role": "User",
          "follows": [
            {
              "$ref": "#/externalBoundedContexts/QlerifyPlatform/domainEvents/OrganisationCreated"
            }
          ],
          "command": {
            "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/commands/CreateProject"
          },
          "aggregateRoot": {
            "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/Project"
          },
          "readModels": [
            {
              "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/queries/ListOrganisations",
              "description": "List Organisations"
            }
          ],
          "acceptanceCriteria": [
            "Given an organisation owner on the dashboard, When they create a project with a name under an organisation, Then the project is created and the creator is added as an admin team member.",
            "Given a user whose subscription project limit is reached, When they try to create a project, Then they are prompted to upgrade."
          ]
        },
        "TeamMemberAdded": {
          "event": "Team Member Added",
          "role": "Automation",
          "follows": [
            {
              "$ref": "#/externalBoundedContexts/QlerifyPlatform/domainEvents/ProjectCreated"
            }
          ],
          "command": {
            "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/commands/AddAdminTeamMember"
          },
          "aggregateRoot": {
            "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/TeamMember"
          },
          "acceptanceCriteria": [
            "Given a newly created project, When project creation completes, Then the creator is automatically added as an admin team member (project membership).",
            "Given a project owner inviting a teammate by email, When they add a team member, Then a membership linking that user or email to the project is created (or a pending invite if the user does not exist yet)."
          ]
        },
        "WorkflowCreated": {
          "event": "Workflow Created",
          "role": "User",
          "follows": [
            {
              "$ref": "#/externalBoundedContexts/QlerifyPlatform/domainEvents/TeamMemberAdded"
            }
          ],
          "command": {
            "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/commands/CreateWorkflow"
          },
          "aggregateRoot": {
            "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/Workflow"
          },
          "readModels": [
            {
              "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/queries/ListProjects",
              "description": "List Projects"
            }
          ],
          "acceptanceCriteria": [
            "Given a team member on a project with FULL subscription access, When they create a workflow with a name, Then a new empty workflow is created in the project and added to their workflow order."
          ]
        }
      },
      "schemas": {
        "commands": {
          "CreateUser": {
            "required": [
              "firstname",
              "lastname",
              "email"
            ],
            "fields": [
              {
                "name": "firstname",
                "hideInForm": false
              },
              {
                "name": "lastname",
                "hideInForm": false
              },
              {
                "name": "email",
                "hideInForm": false
              },
              {
                "name": "company",
                "hideInForm": false
              },
              {
                "name": "phoneNumber",
                "hideInForm": false
              },
              {
                "name": "referralSource",
                "hideInForm": false
              },
              {
                "name": "usageIntent",
                "hideInForm": false
              }
            ]
          },
          "CreateOrganisation": {
            "required": [
              "name"
            ],
            "fields": [
              {
                "name": "name",
                "hideInForm": false
              }
            ]
          },
          "CreateProject": {
            "required": [
              "name",
              "organisationId"
            ],
            "fields": [
              {
                "name": "name",
                "hideInForm": false
              },
              {
                "name": "organisationId",
                "hideInForm": false
              }
            ]
          },
          "AddAdminTeamMember": {
            "required": [
              "projectId",
              "userId"
            ],
            "fields": [
              {
                "name": "projectId",
                "hideInForm": false
              },
              {
                "name": "userId",
                "hideInForm": false
              }
            ]
          },
          "CreateWorkflow": {
            "required": [
              "projectId",
              "name"
            ],
            "fields": [
              {
                "name": "projectId",
                "hideInForm": false
              },
              {
                "name": "name",
                "hideInForm": false
              }
            ]
          }
        },
        "queries": {
          "GetCurrentUser": {
            "description": "Looks up the authenticated user's Qlerify profile to decide whether to create a new profile or update the existing one.",
            "entity": {
              "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/User"
            },
            "fields": [
              {
                "name": "id"
              },
              {
                "name": "email"
              },
              {
                "name": "firstname"
              },
              {
                "name": "lastname"
              }
            ]
          },
          "ListOrganisations": {
            "description": "Lists the organisations the user owns so they can choose which one to create the project under.",
            "entity": {
              "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/Organisation"
            },
            "array": true,
            "fields": [
              {
                "name": "id"
              },
              {
                "name": "name"
              }
            ]
          },
          "ListProjects": {
            "description": "Lists the projects the user is a member of so they can choose which one to create the workflow in.",
            "entity": {
              "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/Project"
            },
            "array": true,
            "fields": [
              {
                "name": "id"
              },
              {
                "name": "name"
              },
              {
                "name": "organisationId"
              }
            ]
          }
        },
        "entities": {
          "User": {
            "description": "Qlerify user profile stored in DynamoDB, created on first login from the Cognito account attributes.",
            "required": [
              "id",
              "email",
              "firstname",
              "lastname"
            ],
            "fields": [
              {
                "name": "id",
                "description": "Unique identifier of the user (matches the Cognito identity)",
                "exampleData": [
                  "a1b2c3d4-1111-2222-3333-444455556666",
                  "f0e9d8c7-aaaa-bbbb-cccc-ddddeeeeffff",
                  "12345678-90ab-cdef-1234-567890abcdef"
                ],
                "dataType": "string"
              },
              {
                "name": "email",
                "description": "User email",
                "exampleData": [
                  "ada@example.com",
                  "grace@company.org",
                  "linus@mail.net"
                ],
                "dataType": "string"
              },
              {
                "name": "firstname",
                "description": "Given name",
                "exampleData": [
                  "Ada",
                  "Grace",
                  "Linus"
                ],
                "dataType": "string"
              },
              {
                "name": "lastname",
                "description": "Family name",
                "exampleData": [
                  "Lovelace",
                  "Hopper",
                  "Torvalds"
                ],
                "dataType": "string"
              },
              {
                "name": "company",
                "description": "Company the user belongs to",
                "exampleData": [
                  "Acme Inc",
                  "Globex",
                  "Initech"
                ],
                "dataType": "string"
              },
              {
                "name": "phoneNumber",
                "description": "Phone number",
                "exampleData": [
                  "+14155550100",
                  "+442071234567",
                  "+46812345678"
                ],
                "dataType": "string"
              },
              {
                "name": "job",
                "description": "Job title",
                "exampleData": [
                  "Product Manager",
                  "Software Architect",
                  "CTO"
                ],
                "dataType": "string"
              },
              {
                "name": "referralSource",
                "description": "How the user heard about Qlerify",
                "exampleData": [
                  "Google search",
                  "A colleague",
                  "Conference talk"
                ],
                "dataType": "string"
              },
              {
                "name": "usageIntent",
                "description": "How the user intends to use Qlerify",
                "exampleData": [
                  "Model our order process",
                  "Document microservices",
                  "Teach DDD"
                ],
                "dataType": "string"
              },
              {
                "name": "picture",
                "description": "Profile picture and its storage location",
                "exampleData": [
                  "Object",
                  "Object",
                  "Object"
                ],
                "relatedEntity": {
                  "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/valueObjects/Picture"
                },
                "dataType": "object"
              },
              {
                "name": "loginCounter",
                "description": "Number of times the user has logged in",
                "exampleData": [
                  "1",
                  "5",
                  "27"
                ],
                "dataType": "number"
              },
              {
                "name": "hasMcpApiKey",
                "description": "Whether the user has generated an MCP API key",
                "exampleData": [
                  "false",
                  "true",
                  "false"
                ],
                "dataType": "boolean"
              }
            ]
          },
          "Organisation": {
            "description": "An entity that runs one or more development projects; owned by the user who created it.",
            "required": [
              "id",
              "name",
              "userId"
            ],
            "fields": [
              {
                "name": "id",
                "description": "Unique identifier of the organisation",
                "exampleData": [
                  "org-1001",
                  "org-2002",
                  "org-3003"
                ],
                "dataType": "string"
              },
              {
                "name": "name",
                "description": "Organisation name",
                "exampleData": [
                  "Acme Inc",
                  "Globex",
                  "Initech"
                ],
                "dataType": "string"
              },
              {
                "name": "userId",
                "description": "Owner of the organisation (references User)",
                "exampleData": [
                  "a1b2c3d4-1111-2222-3333-444455556666",
                  "f0e9d8c7-aaaa-bbbb-cccc-ddddeeeeffff",
                  "12345678-90ab-cdef-1234-567890abcdef"
                ],
                "dataType": "string"
              },
              {
                "name": "projects",
                "description": "Projects under this organisation",
                "array": true,
                "exampleData": [
                  "Object",
                  "Object",
                  "Object"
                ],
                "relatedEntity": {
                  "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/Project"
                },
                "dataType": "object"
              },
              {
                "name": "createdAt",
                "description": "Timestamp when the organisation was created",
                "exampleData": [
                  "2026-01-15T10:00:00Z",
                  "2026-02-03T08:30:00Z",
                  "2026-03-21T14:05:00Z"
                ],
                "dataType": "string"
              },
              {
                "name": "updatedAt",
                "description": "Timestamp when the organisation was last updated",
                "exampleData": [
                  "2026-01-16T09:00:00Z",
                  "2026-02-04T11:30:00Z",
                  "2026-03-22T16:45:00Z"
                ],
                "dataType": "string"
              }
            ]
          },
          "Project": {
            "description": "A workspace under an organisation that groups workflows and team members.",
            "required": [
              "id",
              "name",
              "organisationId"
            ],
            "fields": [
              {
                "name": "id",
                "description": "Unique identifier of the project",
                "exampleData": [
                  "proj-5001",
                  "proj-6002",
                  "proj-7003"
                ],
                "dataType": "string"
              },
              {
                "name": "name",
                "description": "Project name",
                "exampleData": [
                  "Checkout Redesign",
                  "Billing Platform",
                  "Onboarding Revamp"
                ],
                "dataType": "string"
              },
              {
                "name": "organisationId",
                "description": "Organisation this project belongs to (references Organisation)",
                "exampleData": [
                  "org-1001",
                  "org-2002",
                  "org-3003"
                ],
                "dataType": "string"
              },
              {
                "name": "createdAt",
                "description": "Timestamp when the project was created",
                "exampleData": [
                  "2026-01-15T10:05:00Z",
                  "2026-02-03T08:40:00Z",
                  "2026-03-21T14:10:00Z"
                ],
                "dataType": "string"
              },
              {
                "name": "teamMembers",
                "description": "Members of this project",
                "array": true,
                "exampleData": [
                  "Object",
                  "Object",
                  "Object"
                ],
                "relatedEntity": {
                  "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/TeamMember"
                },
                "dataType": "object"
              },
              {
                "name": "workflows",
                "description": "Workflows in this project",
                "array": true,
                "exampleData": [
                  "Object",
                  "Object",
                  "Object"
                ],
                "relatedEntity": {
                  "$ref": "#/externalBoundedContexts/QlerifyPlatform/schemas/entities/Workflow"
                },
                "dataType": "object"
              }
            ]
          },
          "TeamMember": {
            "description": "A membership linking a user to a project, with per-user workflow ordering. The admin membership is auto-created with the project.",
            "required": [
              "id",
              "userId",
              "email",
              "projectId"
            ],
            "fields": [
              {
                "name": "id",
                "description": "Unique identifier of the team member / project membership",
                "exampleData": [
                  "tm-9001",
                  "tm-9002",
                  "tm-9003"
                ],
                "dataType": "string"
              },
              {
                "name": "userId",
                "description": "The member user (references User)",
                "exampleData": [
                  "a1b2c3d4-1111-2222-3333-444455556666",
                  "f0e9d8c7-aaaa-bbbb-cccc-ddddeeeeffff",
                  "12345678-90ab-cdef-1234-567890abcdef"
                ],
                "dataType": "string"
              },
              {
                "name": "email",
                "description": "Email of the member (used for invites before the user exists)",
                "exampleData": [
                  "ada@example.com",
                  "grace@company.org",
                  "linus@mail.net"
                ],
                "dataType": "string"
              },
              {
                "name": "projectId",
                "description": "The project this membership grants access to (references Project)",
                "exampleData": [
                  "proj-5001",
                  "proj-6002",
                  "proj-7003"
                ],
                "dataType": "string"
              },
              {
                "name": "lastLogin",
                "description": "Last time the member accessed the project",
                "exampleData": [
                  "2026-01-20T09:00:00Z",
                  "2026-02-10T13:15:00Z",
                  "2026-03-25T17:45:00Z"
                ],
                "dataType": "string"
              },
              {
                "name": "createdAt",
                "description": "Timestamp when the membership was created",
                "exampleData": [
                  "2026-01-15T10:05:00Z",
                  "2026-02-03T08:40:00Z",
                  "2026-03-21T14:10:00Z"
                ],
                "dataType": "string"
              },
              {
                "name": "workflowOrder",
                "description": "Ordered list of workflow ids as arranged by this member",
                "exampleData": [
                  "wf-abc123,wf-def456",
                  "wf-ghi789",
                  "wf-abc123,wf-def456,wf-ghi789"
                ],
                "dataType": "string"
              },
              {
                "name": "starredWorkflowOrder",
                "description": "Ordered list of starred workflow ids for this member",
                "exampleData": [
                  "wf-abc123",
                  "wf-def456"
                ],
                "dataType": "string"
              }
            ]
